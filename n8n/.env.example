# Copy to n8n Cloud → Settings → Variables, or your self-hosted .env
# Never commit real values.

TWENTY_API_URL=https://your-twenty-instance.com
TWENTY_API_KEY=eyJ...

# Google (Calendar + Drive + Gmail)
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_INVENTORY_FOLDER_ID=
GOOGLE_SHEETS_INVENTORY_ID=

# Email sender (Gmail OAuth in n8n, or SMTP)
OWNER_EMAIL=owner@divisionpr.com
NOREPLY_EMAIL=showroom@divisionpr.com

# Portal onboarding → AUTO-11 webhook secret
ONBOARDING_WEBHOOK_SECRET=generate-a-long-random-string

# Clerk (AUTO-11 portal account provisioning)
CLERK_SECRET_KEY=sk_live_...
