    },
    "Create Return Calendar Event": {
      "main": [[{ "node": "Save Calendar Event ID", "type": "main", "index": 0 }]]
    },
    "Save Calendar Event ID": {
      "main": [[{ "node": "Split Inventory Items", "type": "main", "index": 0 }]]
    },
    "Split Inventory Items": {
      "main": [[{ "node": "Set Item Status Out", "type": "main", "index": 0 }]]
    }
  },
